# Paperclip environment variables
#
# Copy this file to `.env` in the repo root and fill in the values you need.
# Load order is:
#   1. shell/process environment
#   2. `.paperclip/.env` next to the active config file
#   3. repo-root `.env` (this file after you copy it)
#   4. config.json defaults / values
#
# This example documents operator-set variables. Internal runtime-generated vars
# such as `PAPERCLIP_LISTEN_HOST`, `PAPERCLIP_LISTEN_PORT`, `PAPERCLIP_IN_WORKTREE`,
# and `PAPERCLIP_WORKSPACE_*` are intentionally not listed here.
#
# Booleans use `true` / `false`.
# Comma-separated lists should not contain spaces unless the value itself needs them.
#
# Minimum useful setup:
#   - `DATABASE_URL` is always required.
#   - `PAPERCLIP_AGENT_JWT_SECRET` is required for local agent auth and is strongly
#     recommended for every install.
#   - In authenticated/public deployments, also set a public URL and an auth secret
#     (`BETTER_AUTH_SECRET` or reuse `PAPERCLIP_AGENT_JWT_SECRET`).

# ------------------------------------------------------------------------------
# Core required values
# ------------------------------------------------------------------------------

# Required: PostgreSQL connection string used by the server, db:migrate, and Drizzle.
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Required for local agent authentication. In authenticated mode, Better Auth
# also falls back to this value if `BETTER_AUTH_SECRET` is not set.
PAPERCLIP_AGENT_JWT_SECRET=replace-with-a-long-random-secret

# Optional JWT tuning for local agent auth.
# PAPERCLIP_AGENT_JWT_TTL_SECONDS=172800
# PAPERCLIP_AGENT_JWT_ISSUER=paperclip
# PAPERCLIP_AGENT_JWT_AUDIENCE=paperclip-api

# ------------------------------------------------------------------------------
# Server listen and deployment mode
# ------------------------------------------------------------------------------

# HTTP listen host and port for the Paperclip server.
# `local_trusted` mode must bind to a loopback host such as 127.0.0.1 or ::1.
# HOST=127.0.0.1
# PORT=3100

# Serve the built UI from the API server. Set to `false` for API-only deployments.
# SERVE_UI=true

# `local_trusted` = local-only development, no browser auth required.
# `authenticated` = multi-user / non-loopback deployment with Better Auth enabled.
# PAPERCLIP_DEPLOYMENT_MODE=local_trusted

# Only meaningful when `PAPERCLIP_DEPLOYMENT_MODE=authenticated`.
# `private` is for VPN/LAN/internal exposure.
# `public` is internet-facing and requires an explicit public auth base URL.
# PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Additional hostnames accepted for authenticated deployments.
# Comma-separated hostnames only, no scheme or path.
# PAPERCLIP_ALLOWED_HOSTNAMES=paperclip.example.com,admin.paperclip.example.com

# ------------------------------------------------------------------------------
# Public URL and browser auth
# ------------------------------------------------------------------------------

# Canonical public URL for the deployment. Use this when the server sits behind
# a reverse proxy, custom domain, or tunnel. Required for authenticated public
# deployments and recommended for clean invite/callback links.
# PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# Override only the auth callback/base URL. If unset, auth falls back to
# `PAPERCLIP_PUBLIC_URL`.
# PAPERCLIP_AUTH_PUBLIC_BASE_URL=https://paperclip.example.com

# `auto` derives auth base URL from the incoming request.
# `explicit` uses `PAPERCLIP_AUTH_PUBLIC_BASE_URL` or `PAPERCLIP_PUBLIC_URL`.
# Authenticated public deployments must use `explicit`.
# PAPERCLIP_AUTH_BASE_URL_MODE=auto

# Disable self-service sign-up in the email/password auth flow.
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=false

# Better Auth secret for browser/session auth. Required in authenticated mode
# unless you intentionally reuse `PAPERCLIP_AGENT_JWT_SECRET`.
# BETTER_AUTH_SECRET=replace-with-a-second-long-random-secret

# Extra allowed browser origins for Better Auth. Usually you can leave this
# unset if `PAPERCLIP_PUBLIC_URL` and `PAPERCLIP_ALLOWED_HOSTNAMES` already
# describe the deployment correctly.
# BETTER_AUTH_TRUSTED_ORIGINS=https://paperclip.example.com,https://admin.paperclip.example.com

# ------------------------------------------------------------------------------
# Migrations and database backups
# ------------------------------------------------------------------------------

# Force pending migrations to apply automatically at server startup.
# When unset, non-interactive runs already auto-apply; interactive runs prompt.
# PAPERCLIP_MIGRATION_AUTO_APPLY=true

# Set to `never` to skip the interactive migration prompt and leave pending
# migrations unapplied. This wins over `PAPERCLIP_MIGRATION_AUTO_APPLY`.
# PAPERCLIP_MIGRATION_PROMPT=never

# Periodic PostgreSQL backups.
# Leave the path unset to use the instance-aware default path.
# PAPERCLIP_DB_BACKUP_ENABLED=true
# PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
# PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30
# PAPERCLIP_DB_BACKUP_DIR=~/.paperclip/instances/default/data/backups

# ------------------------------------------------------------------------------
# File/object storage
# ------------------------------------------------------------------------------

# `local_disk` stores uploads on the local filesystem.
# `s3` stores uploads in S3-compatible object storage.
# PAPERCLIP_STORAGE_PROVIDER=local_disk

# Only used when `PAPERCLIP_STORAGE_PROVIDER=local_disk`.
# Leave unset to use the instance-aware default storage path.
# PAPERCLIP_STORAGE_LOCAL_DIR=~/.paperclip/instances/default/data/storage

# Only used when `PAPERCLIP_STORAGE_PROVIDER=s3`.
# PAPERCLIP_STORAGE_S3_BUCKET=paperclip
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
# PAPERCLIP_STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# PAPERCLIP_STORAGE_S3_PREFIX=uploads
# PAPERCLIP_STORAGE_S3_FORCE_PATH_STYLE=false

# S3 credentials are resolved by the AWS SDK default credential chain.
# Uncomment these only if you want to provide credentials directly in the env.
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
# AWS_SESSION_TOKEN=replace-me

# ------------------------------------------------------------------------------
# Secret storage
# ------------------------------------------------------------------------------

# Secret provider backend. Only `local_encrypted` is implemented in this repo
# today; the other provider enum values exist but are currently stubs.
# PAPERCLIP_SECRETS_PROVIDER=local_encrypted

# When `true`, routes that depend on secrets fail hard instead of tolerating
# missing provider configuration.
# PAPERCLIP_SECRETS_STRICT_MODE=false

# Provide the local secrets master key directly.
# Accepted formats:
#   - 32-byte base64
#   - 64-char hex
#   - raw 32-char string
# If unset, Paperclip reads or creates the key file below.
# PAPERCLIP_SECRETS_MASTER_KEY=replace-with-a-32-byte-key

# File path for the `local_encrypted` master key. Leave unset to use the
# instance-aware default path.
# PAPERCLIP_SECRETS_MASTER_KEY_FILE=~/.paperclip/instances/default/secrets/master.key

# ------------------------------------------------------------------------------
# Logs, scheduler, uploads, and safety guards
# ------------------------------------------------------------------------------

# Override the server log directory. Leave unset to use the instance default.
# PAPERCLIP_LOG_DIR=~/.paperclip/instances/default/logs

# Directory used for persisted run logs from agent executions.
# Leave unset to use the instance-aware default path.
# RUN_LOG_BASE_PATH=~/.paperclip/instances/default/data/run-logs

# Heartbeat scheduler loop.
# `HEARTBEAT_SCHEDULER_ENABLED=false` disables scheduled wakeups entirely.
# `HEARTBEAT_SCHEDULER_INTERVAL_MS` is clamped to a minimum of 10000.
# HEARTBEAT_SCHEDULER_ENABLED=true
# HEARTBEAT_SCHEDULER_INTERVAL_MS=30000

# Allow destructive company deletion endpoints.
# Defaults to `true` in `local_trusted` mode and `false` in `authenticated` mode.
# PAPERCLIP_ENABLE_COMPANY_DELETION=false

# Allowed attachment MIME types. Default is image-only if unset.
# Examples:
#   image/*
#   image/*,application/pdf
# PAPERCLIP_ALLOWED_ATTACHMENT_TYPES=image/*,application/pdf

# Maximum attachment upload size in bytes. Default is 10485760 (10 MiB).
# PAPERCLIP_ATTACHMENT_MAX_BYTES=10485760

# ------------------------------------------------------------------------------
# CLI, local state, and worktree helpers
# ------------------------------------------------------------------------------

# Root directory for local Paperclip state. Defaults to `~/.paperclip`.
# PAPERCLIP_HOME=~/.paperclip

# Active instance name. Used to derive default config/data/env paths.
# PAPERCLIP_INSTANCE_ID=default

# Override the active config or CLI context file.
# PAPERCLIP_CONFIG=~/.paperclip/instances/default/config.json
# PAPERCLIP_CONTEXT=~/.paperclip/instances/default/context.json

# Defaults for the CLI when talking to a running Paperclip server.
# `PAPERCLIP_API_URL` is the full API base URL.
# `PAPERCLIP_API_KEY` is the bearer token used by agent-authenticated calls.
# `PAPERCLIP_COMPANY_ID` sets the default company context for CLI commands.
# PAPERCLIP_API_URL=http://127.0.0.1:3100
# PAPERCLIP_API_KEY=replace-with-an-agent-token
# PAPERCLIP_COMPANY_ID=company_123

# Fallback host/port used by the CLI only when it has to infer an API base URL.
# Prefer `PAPERCLIP_API_URL` when the server is remote or behind a proxy.
# PAPERCLIP_SERVER_HOST=localhost
# PAPERCLIP_SERVER_PORT=3100

# Default PostgreSQL URL used by `paperclipai worktree` when `--database-url`
# is not passed explicitly.
# PAPERCLIP_WORKTREE_DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip_worktree

# Development-only convenience toggles.
# `PAPERCLIP_UI_DEV_MIDDLEWARE=true` serves the UI through Vite middleware.
# `PAPERCLIP_OPEN_ON_LISTEN=true` opens a browser when a local server starts.
# PAPERCLIP_UI_DEV_MIDDLEWARE=false
# PAPERCLIP_OPEN_ON_LISTEN=false

# ------------------------------------------------------------------------------
# Optional adapter/provider credentials
# ------------------------------------------------------------------------------

# Codex and OpenCode adapters can use OpenAI API-key auth.
# Cursor can also fall back to OPENAI auth when CURSOR_API_KEY is absent.
# OPENAI_API_KEY=replace-me

# Claude local adapter API-key auth. If unset, Claude can use local CLI login/session auth.
# ANTHROPIC_API_KEY=replace-me

# Gemini local adapter auth. Set either GEMINI_API_KEY or GOOGLE_API_KEY, or
# use local Gemini CLI auth instead.
# GEMINI_API_KEY=replace-me
# GOOGLE_API_KEY=replace-me

# Set to `true` to let Gemini use Google Cloud Application Default Credentials.
# GOOGLE_GENAI_USE_GCA=false

# Cursor local adapter API-key auth.
# CURSOR_API_KEY=replace-me

# Override the command name/path used to launch local adapters.
# PAPERCLIP_OPENCODE_COMMAND=opencode
# PAPERCLIP_PI_COMMAND=pi

# Override Codex home if it is not `~/.codex`.
# Paperclip injects skills into `$CODEX_HOME/skills` when needed.
# CODEX_HOME=~/.codex
