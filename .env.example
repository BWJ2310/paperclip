# Paperclip environment variables
#
# Copy to `.env` for repo-local overrides.
# Shell env and `.paperclip/.env` still take precedence.
#
# This file is intentionally populated with safe local defaults.
# If you want embedded PostgreSQL for local dev, comment out `DATABASE_URL`.

# ------------------------------------------------------------------------------
# Core server
# ------------------------------------------------------------------------------
HOST=127.0.0.1
PORT=3100
SERVE_UI=true
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_AUTH_BASE_URL_MODE=auto

# ------------------------------------------------------------------------------
# Database
# Comment out DATABASE_URL to use embedded PostgreSQL instead.
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PAPERCLIP_DB_BACKUP_ENABLED=true
PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30

# PAPERCLIP_DB_BACKUP_DIR=~/.paperclip/instances/default/data/backups
# PAPERCLIP_EMBEDDED_POSTGRES_VERBOSE=false

# ------------------------------------------------------------------------------
# Deployment and auth
# For authenticated deployments, prefer PAPERCLIP_PUBLIC_URL and BETTER_AUTH_SECRET.
# ------------------------------------------------------------------------------
# PAPERCLIP_DEPLOYMENT_EXPOSURE=private
# PAPERCLIP_PUBLIC_URL=http://localhost:3100
# PAPERCLIP_AUTH_PUBLIC_BASE_URL=http://localhost:3100
BETTER_AUTH_URL=http://localhost:3100
BETTER_AUTH_BASE_URL=http://localhost:3100
# PAPERCLIP_ALLOWED_HOSTNAMES=localhost,127.0.0.1
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
# PAPERCLIP_AGENT_JWT_SECRET=replace-with-a-long-random-secret
# PAPERCLIP_AGENT_JWT_TTL_SECONDS=172800
# PAPERCLIP_AGENT_JWT_ISSUER=paperclip
# PAPERCLIP_AGENT_JWT_AUDIENCE=paperclip-api
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3100
# PAPERCLIP_AUTH_DISABLE_SIGN_UP=false

# ------------------------------------------------------------------------------
# Secrets
# ------------------------------------------------------------------------------
PAPERCLIP_SECRETS_PROVIDER=local_encrypted
PAPERCLIP_SECRETS_STRICT_MODE=false

# PAPERCLIP_SECRETS_MASTER_KEY_FILE=~/.paperclip/instances/default/secrets/master.key
# PAPERCLIP_SECRETS_MASTER_KEY=replace-with-a-32-byte-key

# ------------------------------------------------------------------------------
# File storage and uploads
# For S3, credentials come from the normal AWS SDK credential chain.
# ------------------------------------------------------------------------------
PAPERCLIP_STORAGE_PROVIDER=local_disk

# PAPERCLIP_STORAGE_LOCAL_DIR=~/.paperclip/instances/default/data/storage
# PAPERCLIP_STORAGE_S3_BUCKET=paperclip
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
# PAPERCLIP_STORAGE_S3_ENDPOINT=
# PAPERCLIP_STORAGE_S3_PREFIX=
# PAPERCLIP_STORAGE_S3_FORCE_PATH_STYLE=false
# PAPERCLIP_ALLOWED_ATTACHMENT_TYPES=image/*,application/pdf,text/markdown,text/plain,application/json,text/csv,text/html
# PAPERCLIP_ATTACHMENT_MAX_BYTES=10485760

# ------------------------------------------------------------------------------
# Email
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_EMAIL_FROM_ADDRESS="Paperclip <noreply@example.com>"

# ------------------------------------------------------------------------------
# Runtime services and logs
# ------------------------------------------------------------------------------
HEARTBEAT_SCHEDULER_ENABLED=true
HEARTBEAT_SCHEDULER_INTERVAL_MS=30000

# PAPERCLIP_LOG_DIR=~/.paperclip/instances/default/logs
# RUN_LOG_BASE_PATH=~/.paperclip/instances/default/data/run-logs
# PAPERCLIP_ENABLE_COMPANY_DELETION=true
# PAPERCLIP_OPEN_ON_LISTEN=false

# ------------------------------------------------------------------------------
# Local agent adapter defaults
# Set these only if you want host-level defaults; per-agent env or CLI login
# still work for the supported local adapters.
# ------------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# CURSOR_API_KEY=...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...
# PAPERCLIP_OPENCODE_COMMAND=opencode
# PAPERCLIP_PI_COMMAND=pi
# CODEX_HOME=~/.codex

# ------------------------------------------------------------------------------
# Advanced instance/worktree overrides
# Usually better in shell env or `.paperclip/.env`.
# ------------------------------------------------------------------------------
# PAPERCLIP_HOME=~/.paperclip
# PAPERCLIP_INSTANCE_ID=default
# PAPERCLIP_CONFIG=~/.paperclip/instances/default/config.json

# ------------------------------------------------------------------------------
# Dev helpers
# ------------------------------------------------------------------------------
# PAPERCLIP_MIGRATION_PROMPT=never
# PAPERCLIP_MIGRATION_AUTO_APPLY=true
